{
  "show_edit_predictions": false,
  "languages": {
    "Go": {
      "show_edit_predictions": false,
    },
    "Markdown": {
      "preferred_line_length": 90,
      "soft_wrap": "preferred_line_length",
    },
    "YAML": {
      "enable_language_server": true,
    },
  },
  "vim_mode": true,
  "theme": "Ayu Mirage",
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "relative_line_numbers": "enabled",
  "collaboration_panel": {
    "button": false,
  },
}
